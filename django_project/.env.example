# Copy this file to .env for local testing, or set these variables in your
# hosting provider dashboard for production.

DJANGO_SECRET_KEY=replace-this-with-a-long-random-secret-key
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=example.com,www.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com

# Optional. Leave unset to use local SQLite. Set for production PostgreSQL.
# Example:
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DB_NAME
DATABASE_URL=

# Static files are served by WhiteNoise after collectstatic.
DJANGO_STATICFILES_STORAGE=whitenoise.storage.CompressedManifestStaticFilesStorage

# Media files. Configure this path for the deployment server if you keep
# uploaded files outside the project directory.
DJANGO_MEDIA_URL=/media/
DJANGO_MEDIA_ROOT=

# HTTPS/security. Keep true on production HTTPS deployments.
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SESSION_COOKIE_SECURE=true
DJANGO_CSRF_COOKIE_SECURE=true
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=true
DJANGO_SECURE_HSTS_PRELOAD=true
DJANGO_SECURE_REFERRER_POLICY=same-origin
DJANGO_X_FRAME_OPTIONS=DENY

# Optional fallback only. Prefer nginx/object storage for media in production.
DJANGO_SERVE_MEDIA=0
